# Copy to .env for local development.
# Never commit real API keys or secrets.
TEAM_FACTORY_ENV=local
TEAM_FACTORY_LOG_LEVEL=INFO
# The default provider remains deterministic; this is the model id used when a
# real provider is explicitly enabled.
TEAM_FACTORY_DEFAULT_LLM_MODEL=gpt-5.5-codex
TEAM_FACTORY_DEFAULT_LLM_REASONING_EFFORT=medium
# Uncomment only for deliberate local real-LLM smoke tests. The codex_exec
# provider uses your local Codex CLI sign-in and does not need OPENAI_API_KEY.
# TEAM_FACTORY_ENABLE_REAL_LLM=1
# OPENAI_API_KEY=sk-...
